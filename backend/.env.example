# Copy to .env and edit.

# Required in all environments.
SECRET_KEY=replace-me-with-a-real-secret

# Dev defaults are safe; leave DEBUG unset in production.
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database. Defaults to sqlite at backend/db.sqlite3.
# For production, use a Postgres connection string:
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# CSRF trusted origins (production only, include https://).
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# CV default language: "is" or "en".
CV_DEFAULT_LANGUAGE=is

LANGUAGE_CODE=en-us
TIME_ZONE=UTC
